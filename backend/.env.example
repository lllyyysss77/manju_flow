APP_ENV=local

# 服务器配置
SERVER_PORT=8080
GIN_MODE=debug

# 数据库配置
# 支持 sqlite 和 mysql
DB_DRIVER=sqlite
DB_NAME=manju_flow

# MySQL 配置（当 DB_DRIVER=mysql 时使用）
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=manju_flow

# 阿里云 OSS 配置（可选，用于文件上传）
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET_NAME=your_bucket_name

# 音频合成服务配置（用于音频后期中的克隆工作室）
# 指向可访问的 IndexTTS /api/v1/tts 接口
TTS_API_URL=https://owx-2cv9qmtl7tle2ec3o-mdoeuere-custom.service.onethingrobot.com/api/v1/tts
# 如果 inference 服务启用了 JWT_PUBLIC_KEY，这里需要配置对应的 RSA 私钥
# 多行 PEM 需要写成 \n 形式
# TTS_JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# 生成给 inference 服务的 JWT 有效期（秒）
TTS_JWT_EXPIRE_SECONDS=60

# 火山引擎 Ark 视频生成服务配置（用于动画制作中的 Seedance 视频工作台）
ARK_API_BASE_URL=https://ark.cn-beijing.volces.com
# ARK_API_KEY=ark-xxx

# CORS 跨域配置
# 生产环境应配置具体的前端域名，多个用逗号分隔
# CORS_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
CORS_ORIGINS=*

# 注册白名单配置
# 只有在白名单中的用户名（邮箱）才能注册，多个用逗号分隔
# REGISTER_WHITELIST=user1@example.com,user2@example.com
